# ConvoOps backend environment example
# Copy to .env and set real values.

# ------------------------------------------------------------------------------
# OpenAI models
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# ------------------------------------------------------------------------------
# GitHub issue workflow
# ------------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# ------------------------------------------------------------------------------
# Gmail MCP (follow-up emails)
# ------------------------------------------------------------------------------
# Transport: stdio | streamable_http | sse
GMAIL_MCP_TRANSPORT=stdio

# stdio mode
GMAIL_MCP_COMMAND=npx
GMAIL_MCP_ARGS=-y mcp-gmail

# remote mode
GMAIL_MCP_URL=
GMAIL_MCP_AUTH_TOKEN=
# Example: {"Authorization":"Bearer <token>","X-Custom":"value"}
GMAIL_MCP_HEADERS_JSON=

# ------------------------------------------------------------------------------
# Google Drive MCP (term sheet docs)
# ------------------------------------------------------------------------------
# Transport: stdio | streamable_http | sse
GDRIVE_MCP_TRANSPORT=stdio

# stdio mode
GDRIVE_MCP_COMMAND=npx
GDRIVE_MCP_ARGS=-y mcp-google-drive

# remote mode
GDRIVE_MCP_URL=
GDRIVE_MCP_AUTH_TOKEN=
# Example: {"Authorization":"Bearer <token>","X-Custom":"value"}
GDRIVE_MCP_HEADERS_JSON=

# ------------------------------------------------------------------------------
# Calendar MCP (meeting scheduling)
# ------------------------------------------------------------------------------
# Transport: stdio | streamable_http | sse
GCAL_MCP_TRANSPORT=stdio

# stdio mode
GCAL_MCP_COMMAND=npx
GCAL_MCP_ARGS=-y mcp-google-calendar

# remote mode
GCAL_MCP_URL=
GCAL_MCP_AUTH_TOKEN=
# Example: {"Authorization":"Bearer <token>","X-Custom":"value"}
GCAL_MCP_HEADERS_JSON=
